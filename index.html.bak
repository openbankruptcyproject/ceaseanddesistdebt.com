<!-- GEO CARD (timezone-based state suggestion) -->
<div id="geo-card" style="display:none;max-width:700px;margin:1.5rem auto;padding:0 1rem">
<div style="background:#161b22;border:1px solid #30363d;border-radius:8px;padding:1.25rem;text-align:center">
<p id="geo-heading" style="color:#f0f6fc;font-weight:600;font-size:1rem;margin:0 0 0.5rem">Filing in Your State?</p>
<p style="color:#9eaab6;font-size:0.88rem;margin:0 0 0.75rem">Exemptions vary dramatically by state. Check what you can protect.</p>
<a href="https://bankruptcyexemptionsbystate.com/states/?utm_source=ceaseanddesistdebt.com&amp;utm_medium=geo-card&amp;utm_campaign=btn-funnel" id="geo-link" style="display:inline-block;background:#238636;color:#fff;padding:0.45rem 1.25rem;border-radius:6px;font-weight:600;font-size:0.88rem;text-decoration:none">Browse Your State's Exemptions →</a>
</div>
</div>
<script>
(function(){
  try {
    var tz = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
    var map = {
      'America/New_York': {s:'new-york',n:'New York'},
      'America/Chicago': {s:'illinois',n:'Illinois'},
      'America/Denver': {s:'colorado',n:'Colorado'},
      'America/Los_Angeles': {s:'california',n:'California'},
      'America/Phoenix': {s:'arizona',n:'Arizona'},
      'America/Anchorage': {s:'alaska',n:'Alaska'},
      'Pacific/Honolulu': {s:'hawaii',n:'Hawaii'},
      'America/Indiana/Indianapolis': {s:'indiana',n:'Indiana'},
      'America/Detroit': {s:'michigan',n:'Michigan'},
      'America/Kentucky/Louisville': {s:'kentucky',n:'Kentucky'},
      'America/Boise': {s:'idaho',n:'Idaho'}
    };
    var info = map[tz];
    if (!info) {
      if (tz.indexOf('America/New_York') !== -1 || tz.indexOf('Eastern') !== -1) info = map['America/New_York'];
      else if (tz.indexOf('America/Chicago') !== -1 || tz.indexOf('Central') !== -1) info = map['America/Chicago'];
      else if (tz.indexOf('America/Denver') !== -1 || tz.indexOf('Mountain') !== -1) info = map['America/Denver'];
      else if (tz.indexOf('America/Los_Angeles') !== -1 || tz.indexOf('Pacific') !== -1) info = map['America/Los_Angeles'];
    }
    if (info) {
      var src = 'ceaseanddesistdebt.com';
      document.getElementById('geo-heading').textContent = 'Filing in ' + info.n + '?';
      document.getElementById('geo-link').href = 'https://bankruptcyexemptionsbystate.com/states/' + info.s + '.html?utm_source=' + src + '&utm_medium=geo-card&utm_campaign=btn-funnel';
      document.getElementById('geo-link').textContent = info.n + ' Bankruptcy Exemptions \u2192';
    }
    document.getElementById('geo-card').style.display = 'block';
  } catch(e) {}
})();
</script>
<!-- /GEO CARD -->
